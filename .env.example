# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://dealervoice:password@localhost:5432/dealervoice"

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Auth ────────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-super-secret-nextauth-secret-min-32-chars"

# ─── OAuth Providers ─────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""
APPLE_CLIENT_ID=""
APPLE_CLIENT_SECRET=""

# ─── Stripe Payment Gateway (primary) ────────────────────────────────────────
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# Set after creating webhook endpoint in Stripe Dashboard
STRIPE_WEBHOOK_SECRET=""
# Optional — create in Stripe Dashboard → Products, or leave blank to use inline price_data
STRIPE_PRO_MONTHLY_PRICE_ID=""
STRIPE_PRO_ANNUAL_PRICE_ID=""
STRIPE_ENTERPRISE_MONTHLY_PRICE_ID=""
STRIPE_ENTERPRISE_ANNUAL_PRICE_ID=""

# ─── Cashfree (legacy test routes only) ──────────────────────────────────────
# CASHFREE_APP_ID=""
# CASHFREE_SECRET_KEY=""
# CASHFREE_WEBHOOK_SECRET=""
# NEXT_PUBLIC_CASHFREE_APP_ID=""
# CASHFREE_ENV="sandbox"

# ─── Company (public positioning) ────────────────────────────────────────────
NEXT_PUBLIC_COMPANY_HQ_CITY="Chicago"
NEXT_PUBLIC_COMPANY_HQ_STATE="Illinois"
NEXT_PUBLIC_COMPANY_HQ_COUNTRY="United States"

# ─── Business legal (optional — only if you choose to display on site) ───────
# NEXT_PUBLIC_BUSINESS_GSTIN=""
# NEXT_PUBLIC_BUSINESS_CIN=""

# ─── AI ──────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=""
OPENAI_API_KEY="sk-..."
NEXT_PUBLIC_AI_ENABLED="true"

# ─── Sarvam (Support Chat) ───────────────────────────────────────────────────
SARVAM_API_KEY=""

# ─── Resend (Email) ──────────────────────────────────────────────────────────
RESEND_API_KEY="re_..."
EMAIL_DOMAIN="dealervoice.io"
EMAIL_FROM="DealerVoice <dealers@dealervoice.io>"
ADMIN_NOTIFICATION_EMAIL="info@dealervoice.io"

# ─── Namecheap DNS (npm run mail:configure-zoho) ─────────────────────────────
# Whitelist NAMECHEAP_CLIENT_IP at namecheap.com → Profile → Tools → API Access
# NAMECHEAP_API_USER=""
# NAMECHEAP_API_KEY=""
# NAMECHEAP_USERNAME=""
# NAMECHEAP_CLIENT_IP=""

# ─── AWS S3 / R2 ─────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
S3_BUCKET="dealervoice-media"
S3_ENDPOINT=""  # Leave blank for AWS, set for Cloudflare R2 / MinIO
NEXT_PUBLIC_CDN_URL="https://cdn.dealervoice.com"
NEXT_PUBLIC_CDN_DOMAIN="cdn.dealervoice.com"

# ─── Meilisearch ─────────────────────────────────────────────────────────────
MEILISEARCH_HOST="http://localhost:7700"
MEILISEARCH_API_KEY="masterkey"

# ─── PostHog Analytics ───────────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY="phc_..."
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# ─── Google Maps ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_KEY=""

# ─── Google AdSense ─────────────────────────────────────────────────────────
NEXT_PUBLIC_ADSENSE_CLIENT_ID="ca-pub-XXXXXXXXXXXXXXXX"
# Optional display ad unit slot IDs (from AdSense → Ads → By ad unit)
NEXT_PUBLIC_ADSENSE_SLOT_BLOG_IN_ARTICLE=""
NEXT_PUBLIC_ADSENSE_SLOT_BLOG_LIST=""
NEXT_PUBLIC_ADSENSE_SLOT_DEALER_SIDEBAR=""

# ─── Admitad affiliate (India) ───────────────────────────────────────────────
ADMITAD_CLIENT_ID=""
ADMITAD_CLIENT_SECRET=""
ADMITAD_SUBID="dealervoice"
# Optional: your website/adspace ID from Admitad dashboard
ADMITAD_WEBSITE_ID=""

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
