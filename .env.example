# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://dealervoice:password@localhost:5432/dealervoice"

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Auth ────────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-super-secret-nextauth-secret-min-32-chars"

# ─── OAuth Providers ─────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""
APPLE_CLIENT_ID=""
APPLE_CLIENT_SECRET=""

# ─── Cashfree Payment Gateway ────────────────────────────────────────────────
CASHFREE_APP_ID=""
CASHFREE_SECRET_KEY=""
CASHFREE_WEBHOOK_SECRET=""
NEXT_PUBLIC_CASHFREE_APP_ID=""
# sandbox | production
CASHFREE_ENV="sandbox"

# ─── AI ──────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=""
OPENAI_API_KEY="sk-..."
NEXT_PUBLIC_AI_ENABLED="true"

# ─── Sarvam (Support Chat) ───────────────────────────────────────────────────
SARVAM_API_KEY=""

# ─── Resend (Email) ──────────────────────────────────────────────────────────
RESEND_API_KEY="re_..."
EMAIL_DOMAIN="dealervoice.com"

# ─── AWS S3 / R2 ─────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
S3_BUCKET="dealervoice-media"
S3_ENDPOINT=""  # Leave blank for AWS, set for Cloudflare R2 / MinIO
NEXT_PUBLIC_CDN_URL="https://cdn.dealervoice.com"
NEXT_PUBLIC_CDN_DOMAIN="cdn.dealervoice.com"

# ─── Meilisearch ─────────────────────────────────────────────────────────────
MEILISEARCH_HOST="http://localhost:7700"
MEILISEARCH_API_KEY="masterkey"

# ─── PostHog Analytics ───────────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY="phc_..."
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# ─── Google Maps ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_KEY=""

# ─── Google AdSense ─────────────────────────────────────────────────────────
NEXT_PUBLIC_ADSENSE_CLIENT_ID="ca-pub-XXXXXXXXXXXXXXXX"
# Optional display ad unit slot IDs (from AdSense → Ads → By ad unit)
NEXT_PUBLIC_ADSENSE_SLOT_BLOG_IN_ARTICLE=""
NEXT_PUBLIC_ADSENSE_SLOT_BLOG_LIST=""
NEXT_PUBLIC_ADSENSE_SLOT_DEALER_SIDEBAR=""

# ─── Admitad affiliate (India) ───────────────────────────────────────────────
ADMITAD_CLIENT_ID=""
ADMITAD_CLIENT_SECRET=""
ADMITAD_SUBID="dealervoice"
# Optional: your website/adspace ID from Admitad dashboard
ADMITAD_WEBSITE_ID=""

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
