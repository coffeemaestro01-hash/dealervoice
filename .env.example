# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://dealervoice:password@localhost:5432/dealervoice"

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Auth ────────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-super-secret-nextauth-secret-min-32-chars"

# ─── OAuth Providers ─────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""
APPLE_CLIENT_ID=""
APPLE_CLIENT_SECRET=""

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRO_MONTHLY_PRICE_ID="price_..."
STRIPE_PRO_ANNUAL_PRICE_ID="price_..."
STRIPE_ENTERPRISE_MONTHLY_PRICE_ID="price_..."
STRIPE_ENTERPRISE_ANNUAL_PRICE_ID="price_..."

# ─── AI ──────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=""
OPENAI_API_KEY="sk-..."
NEXT_PUBLIC_AI_ENABLED="true"

# ─── Razorpay ────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""
NEXT_PUBLIC_RAZORPAY_KEY_ID=""
RAZORPAY_PRO_MONTHLY_PLAN_ID=""
RAZORPAY_PRO_ANNUAL_PLAN_ID=""
RAZORPAY_ENTERPRISE_MONTHLY_PLAN_ID=""
RAZORPAY_ENTERPRISE_ANNUAL_PLAN_ID=""

# ─── Sarvam (Support Chat) ───────────────────────────────────────────────────
SARVAM_API_KEY=""

# ─── Resend (Email) ──────────────────────────────────────────────────────────
RESEND_API_KEY="re_..."
EMAIL_DOMAIN="dealervoice.com"

# ─── AWS S3 / R2 ─────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
S3_BUCKET="dealervoice-media"
S3_ENDPOINT=""  # Leave blank for AWS, set for Cloudflare R2 / MinIO
NEXT_PUBLIC_CDN_URL="https://cdn.dealervoice.com"
NEXT_PUBLIC_CDN_DOMAIN="cdn.dealervoice.com"

# ─── Meilisearch ─────────────────────────────────────────────────────────────
MEILISEARCH_HOST="http://localhost:7700"
MEILISEARCH_API_KEY="masterkey"

# ─── PostHog Analytics ───────────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY="phc_..."
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# ─── Google Maps ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_KEY=""

# ─── Google AdSense ─────────────────────────────────────────────────────────
NEXT_PUBLIC_ADSENSE_CLIENT_ID="ca-pub-XXXXXXXXXXXXXXXX"
# Optional display ad unit slot IDs (from AdSense → Ads → By ad unit)
NEXT_PUBLIC_ADSENSE_SLOT_BLOG_IN_ARTICLE=""
NEXT_PUBLIC_ADSENSE_SLOT_BLOG_LIST=""
NEXT_PUBLIC_ADSENSE_SLOT_DEALER_SIDEBAR=""

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
