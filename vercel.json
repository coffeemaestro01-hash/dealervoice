{
  "framework": "nextjs",
  "buildCommand": "prisma generate && next build",
  "installCommand": "npm install",
  "regions": ["iad1"],
  "crons": [
    {
      "path": "/api/cron/update-reputation",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/weekly-digest",
      "schedule": "0 8 * * 1"
    },
    {
      "path": "/api/cron/sync-geo-counts",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/linkedin-post",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/cron/growth-sprint",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/outreach-drip",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/discover-emails",
      "schedule": "0 6 * * 2"
    }
  ]
}
